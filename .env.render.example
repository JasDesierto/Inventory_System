# Production template. Prefer secure prompting or env-based password resets over command-line secrets.
APP_ENV=production
SECRET_KEY=replace-with-a-32-plus-character-random-secret
# Supabase session pooler example for this project:
DATABASE_URL=postgresql+psycopg2://postgres.ddlhsbvtjqfaoxbujpkp:your-url-encoded-db-password@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require
SESSION_COOKIE_SECURE=1
TRUSTED_HOSTS=inventory.company.local
ALLOW_SELF_SIGNUP=0
AUTO_SEED_ON_START=0
PROXY_FIX_X_FOR=1
PROXY_FIX_X_PROTO=1
PROXY_FIX_X_HOST=0
PROXY_FIX_X_PORT=0
PROXY_FIX_X_PREFIX=0
AUTH_RATE_LIMIT_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=900
SIGNUP_RATE_LIMIT_ATTEMPTS=5
SIGNUP_RATE_LIMIT_WINDOW_SECONDS=3600
SEED_ADMIN_PASSWORD=replace-with-a-strong-admin-password
PORT=8000
