# Development template only. Do not use these defaults in production.
APP_ENV=development
SECRET_KEY=replace-with-a-32-plus-character-random-secret
DATABASE_URL=sqlite:///inventory.db
SESSION_COOKIE_SECURE=0
TRUSTED_HOSTS=
ALLOW_SELF_SIGNUP=1
AUTO_SEED_ON_START=1
PROXY_FIX_X_FOR=0
PROXY_FIX_X_PROTO=0
PROXY_FIX_X_HOST=0
PROXY_FIX_X_PORT=0
PROXY_FIX_X_PREFIX=0
AUTH_RATE_LIMIT_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=900
SIGNUP_RATE_LIMIT_ATTEMPTS=5
SIGNUP_RATE_LIMIT_WINDOW_SECONDS=3600
SEED_ADMIN_PASSWORD=replace-with-a-strong-admin-password
PORT=8000
